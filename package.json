{
  "name": "futures-risk-position-calculator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "data:build": "python scripts/build_china_futures_contracts.py",
    "data:check": "python scripts/build_china_futures_contracts.py --check",
    "data:sync": "python scripts/sync_official_contracts.py",
    "data:fees:build": "python scripts/build_exchange_fee_margins.py",
    "data:fees:sync": "python scripts/sync_exchange_fee_margins.py",
    "data:update": "python scripts/build_china_futures_contracts.py && python scripts/sync_official_contracts.py && python scripts/build_exchange_fee_margins.py && python scripts/sync_exchange_fee_margins.py",
    "data:check-all": "python scripts/check_data_pipeline.py",
    "test:data-pipeline": "python scripts/test_data_pipeline.py"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
