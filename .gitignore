outputs/*.xls
outputs/*.xlsm
# This reviewed snapshot is intentionally public so dynamic-fee artifacts can be reproduced.
!outputs/exchange_fee_margin_snapshot.xlsx

# Local records and exports must never enter the public repository.
history/
private/
user-data/
*交易记录*
*交割单*

# Local agent handoffs and development artefacts are not project documentation.
HANDOFF*.md
.hermes/
vite-dev.log

# Generated caches and editable source documents are not needed to build the public project.
__pycache__/
*.py[cod]
outputs/*.docx
